# ── Copy this file to .env and fill in real values ────────────────────────────
# NEVER commit .env — it is gitignored.

# ── Backend ───────────────────────────────────────────────────────────────────
# Directory where all host-mounted data is stored (inside the container)
DATA_DIR=/app/data

# Secret key used for internal signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-secret

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ollama (Gemma 3) ──────────────────────────────────────────────────────────
# Host machine address reachable from inside Docker containers
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the backend API (used by the browser, not the container network)
NEXT_PUBLIC_API_URL=http://localhost:8000
